generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model IncomeCategory {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  incomes Income[]
}

model ExpenseCategory {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  expenses Expense[]
  budgets  Budget[]
}

model Income {
  id          Int            @id @default(autoincrement())
  date        DateTime
  categoryId  Int
  description String
  amount      Float
  createdAt   DateTime       @default(now())
  category IncomeCategory @relation(fields: [categoryId], references: [id])
}

model Expense {
  id          Int             @id @default(autoincrement())
  date        DateTime
  categoryId  Int
  description String
  amount      Float
  createdAt   DateTime        @default(now())
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
}

model DebtSource {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  initialAmount Float         @default(0)
  loans         DebtLoan[]
  payments      DebtPayment[]
}

model DebtLoan {
  id           Int        @id @default(autoincrement())
  date         DateTime
  debtSourceId Int
  amount       Float
  description  String     @default("")
  createdAt    DateTime   @default(now())
  debtSource DebtSource @relation(fields: [debtSourceId], references: [id])
}

model DebtPayment {
  id           Int        @id @default(autoincrement())
  date         DateTime
  debtSourceId Int
  amount       Float
  description  String     @default("")
  createdAt    DateTime   @default(now())
  debtSource DebtSource @relation(fields: [debtSourceId], references: [id])
}

model ReceivablePerson {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  receivables Receivable[]
}

model Receivable {
  id        Int              @id @default(autoincrement())
  date      DateTime
  personId  Int
  amount    Float
  type      String           // "given" or "received"
  createdAt DateTime         @default(now())
  person  ReceivablePerson @relation(fields: [personId], references: [id])
}

model Budget {
  id            Int             @id @default(autoincrement())
  categoryId    Int             @unique
  monthlyAmount Float
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
}

model FinancialProfile {
  id             Int       @id @default(autoincrement())
  monthlyIncome  Float     @default(0)
  monthlyExpense Float     @default(0)
  birthDate      DateTime?
  retirementAge  Int       @default(60)
  inheritanceAge Int       @default(80)
}
